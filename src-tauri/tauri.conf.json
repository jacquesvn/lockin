{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lockin",
  "version": "0.6.1",
  "identifier": "gg.lockin.desktop",
  "build": {
    "frontendDist": "../docs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lockin — your pocket CS2 coach",
        "width": 680,
        "height": 920,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
